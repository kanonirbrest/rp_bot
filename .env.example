# Токен от @BotFather
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ

# ID группы (отрицательное число, например -1001234567890)
# Чтобы узнать ID: добавь @userinfobot в группу и напиши /start
GROUP_ID=-1001234567890

# Ссылка-приглашение в группу
# Создаётся в настройках группы → Пригласительная ссылка
GROUP_INVITE_LINK=https://t.me/+xxxxxxxxxxxxxxxxxx

# Твой Telegram user_id (можно узнать у @userinfobot)
# Несколько ID через запятую: 111111,222222
ADMIN_IDS=111111111

# Turso — база промокодов NR-* (выдаются ботом, погашаются через API)
TURSO_URL=libsql://your-db.turso.io
TURSO_TOKEN=eyJ...

# URL сервера бота для webhook (Render и т.п.)
WEBHOOK_URL=https://your-bot.onrender.com

# Секрет для POST /api/promo/redeem (тот же PROMO_API_SECRET во втором приложении)
# openssl rand -hex 32
PROMO_API_SECRET=

# Опционально (значения по умолчанию совпадают с ботом)
# PROMO_DISCOUNT_PERCENT=10
# PROMO_CAMPAIGN_VALID_UNTIL=01.07.2026
